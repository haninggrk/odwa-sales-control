<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_picking_lock_wizard_form" model="ir.ui.view">
        <field name="name">stock.picking.lock.wizard.form</field>
        <field name="model">stock.picking.lock.wizard</field>
        <field name="arch" type="xml">
            <form string="Lock Delivery Date?">
                <group>
                    <p>Tanggal pengiriman telah diubah. Apakah Anda ingin mengunci tanggal ini dan memberitahu customer via WhatsApp?</p>
                    <field name="picking_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_lock" type="object" string="Lock &amp; Notify Customer"
                            class="btn-primary"/>
                    <button name="action_skip" type="object" string="Skip" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
